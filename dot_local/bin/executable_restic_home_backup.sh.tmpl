{{ if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash

source "$HOME/Documents/HomeServer/.privaterc.sh"

export PATH="/opt/homebrew/bin:$PATH"
export RESTIC_REPOSITORY="sftp:truenas_admin@192.168.1.83:/mnt/main/backups/mba"

restic backup \
  $HOME/Documents \
  $HOME/Projects \
  $HOME/.ssh \
  $HOME/.aws \
  --exclude="$HOME/Documents/university.tar.gz" \
  --exclude="$HOME/Projects/coord-buffer/map/*.mbtiles" \
  --exclude="$HOME/Projects/DTED/tarFiles" \
  --exclude="$HOME/Projects/DTED/DTED" \
  --exclude="*/node_modules" \
  --exclude="*/.git" \
  --tag "home" \
  --verbose

echo "Pruning old backups..."
restic forget \
  --keep-daily 7 \
  --keep-weekly 4 \
  --keep-monthly 12 \
  --prune \
  --tag "home"

echo "Finished $(date +'%Y-%m-%d %H:%M:%S')"
{{ end -}}
